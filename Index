<script>
function showVisit(n, btn) {
  document.querySelectorAll('.visit').forEach(v => v.classList.remove('show'));
  document.getElementById('visit' + n).classList.add('show');
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  window.scrollTo({top: 0});
}
function tick(input) {
  const visit = input.closest('.visit');
  const boxes = visit.querySelectorAll('input[type=checkbox]');
  const done = [...boxes].filter(b => b.checked).length;
  const pct = Math.round(done / boxes.length * 100);
  visit.querySelector('.bar').style.width = pct + '%';
  visit.querySelector('.ptext').textContent = done + ' of ' + boxes.length + ' done';
}
document.getElementById('visit1').classList.add('show');
</script>
