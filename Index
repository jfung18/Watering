<title>Watering · Jun 13–24</title>
<style>
:root {
  --moss: #2D4A2E; --sage: #6B9E6F; --terracotta: #C4714A;
  --parchment: #F4F0E6; --ink: #1C2B1D; --muted: #7A7264;
  --cream: #FBF9F4; --gold: #B8963E;
}
* { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  background: var(--cream); color: var(--ink);
  padding-bottom: 40px;
}
header {
  background: var(--moss); color: white; padding: 18px 16px 14px;
  position: sticky; top: 0; z-index: 10;
}
header h1 { font-size: 19px; font-weight: 700; }
header .sub { font-size: 13px; opacity: 0.85; margin-top: 2px; }
.tabs {
  display: flex; gap: 6px; margin-top: 12px;
}
.tab {
  flex: 1; text-align: center; padding: 8px 4px; border-radius: 8px;
  background: rgba(255,255,255,0.15); color: white; font-size: 12.5px;
  font-weight: 600; cursor: pointer; border: none; line-height: 1.3;
}
.tab small { display: block; font-weight: 400; font-size: 10.5px; opacity: 0.85; }
.tab.active { background: white; color: var(--moss); }
main { max-width: 560px; margin: 0 auto; padding: 14px 12px; }
.visit { display: none; }
.visit.show { display: block; }
.visit-head { margin-bottom: 12px; }
.visit-head h2 { font-size: 21px; color: var(--moss); }
.vdate { color: var(--terracotta); font-weight: 600; font-size: 14px; margin: 2px 0 8px; }
.progress {
  background: #E5E0D3; border-radius: 99px; height: 22px; position: relative; overflow: hidden;
}
.progress .bar {
  background: var(--sage); height: 100%; width: 0%; border-radius: 99px;
  transition: width 0.3s ease;
}
.progress .ptext {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 600; color: var(--ink);
}
.hotnote {
  background: #FBEEE3; border: 1px solid #EFD3BC; border-radius: 12px;
  padding: 10px 14px; font-size: 12.5px; margin-bottom: 12px; line-height: 1.45;
}
h3 {
  font-size: 13px; text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--muted); margin: 18px 0 8px;
}
.card {
  display: flex; align-items: center; gap: 12px;
  background: white; border: 1px solid #E5E0D3; border-radius: 14px;
  padding: 10px 12px; margin-bottom: 8px; cursor: pointer;
  transition: opacity 0.2s, background 0.2s;
}
.card input { display: none; }
.card .photo img {
  width: 58px; height: 58px; border-radius: 10px; display: block; object-fit: cover;
}
.card .info { flex: 1; min-width: 0; }
.card .name { font-weight: 700; font-size: 15px; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.badge {
  font-size: 9.5px; font-weight: 700; padding: 2px 7px; border-radius: 99px; letter-spacing: 0.04em;
}
.badge.bottom { background: #E3EDE4; color: var(--moss); }
.badge.top { background: #F6E7DC; color: var(--terracotta); }
.cups { font-size: 13.5px; color: var(--ink); margin-top: 3px; font-weight: 600; }
.loc { font-size: 12px; color: var(--muted); margin-top: 1px; }
.note {
  font-size: 11.5px; color: var(--gold); margin-top: 4px; font-style: italic; line-height: 1.35;
}
.check {
  width: 30px; height: 30px; border-radius: 99px; border: 2px solid #D8D2C2;
  display: flex; align-items: center; justify-content: center;
  color: transparent; font-weight: 700; flex-shrink: 0; font-size: 16px;
}
.card:has(input:checked) { background: var(--parchment); opacity: 0.65; }
.card:has(input:checked) .check { background: var(--sage); border-color: var(--sage); color: white; }
.card:has(input:checked) .name { text-decoration: line-through; text-decoration-thickness: 2px; }
.legend {
  background: var(--parchment); border-radius: 12px; padding: 10px 14px;
  font-size: 12px; color: var(--ink); margin-bottom: 14px; line-height: 1.5;
}
.legend b { color: var(--moss); }
footer {
  text-align: center; font-size: 11px; color: var(--muted); margin-top: 24px; line-height: 1.6;
}
</style>
</head>
